# Copy this file to secrets.env and fill in real values.
# secrets.env is gitignored locally by default — see README for how the
# cloud scheduled agent actually gets these values.

FRED_API_KEY=
EIA_API_KEY=
EXIM_API_KEY=

KIS_APP_KEY=
KIS_APP_SECRET=

# Twelve Data (https://twelvedata.com) — 미국 지수(ETF 대리 지표)
TWELVEDATA_API_KEY=
# Finnhub (https://finnhub.io) — 미국 관심 종목
FINNHUB_API_KEY=

# Resend (https://resend.com) — HTTPS 이메일 발송. RESEND_FROM_EMAIL은 보통
# Resend 대시보드가 계정 생성 시 제공하는 기본 발신 도메인(예: onboarding@resend.dev)이며,
# 커스텀 도메인을 검증하면 원하는 주소로 바꿀 수 있다.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
REPORT_TO_EMAIL=jilee.kor@gmail.com
